  nombreEntrevistado: Sakamoto
  preguntas:
  - preguntaEspanol: Preguntarle el nombre
    preguntaJapones: 
    opciones:
    - textoOpcion: O namae wa nan desu ka?
      respuestaDelNPC: Kenji Sakamoto desu. Yoroshiku!
