      puntaje: 2
      reaccion: 0
    - textoOpcion: Namae ga suki desu ka?
      respuestaDelNPC: "Esa es una pregunta extra\xF1a..."
      esCorrecta: 0
      puntaje: 0
      reaccion: 2
    - textoOpcion: Nan sai desu ka?
      respuestaDelNPC: "No deber\xEDas preguntar mi nombre primero?"
      esCorrecta: 0
      puntaje: 1
      reaccion: 1
  - preguntaEspanol: "Preguntar qu\xE9 le gusta"
    preguntaJapones: 
    opciones:
    - textoOpcion: Nani ga suki desu ka?
      respuestaDelNPC: 
      esCorrecta: 1
      puntaje: 2
      reaccion: 0
    - textoOpcion: Nani ga tabemasu ka?
      respuestaDelNPC: No es hora de comer...
      esCorrecta: 0
      puntaje: 0
      reaccion: 3
  - preguntaEspanol: Dale las gracias
    preguntaJapones: 
